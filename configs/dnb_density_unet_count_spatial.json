{
  "schema_version": 2,
  "experiment_family": "dnb_density_heatmap",
  "role": "main",
  "status": "pilot_count_spatial_factorized",
  "locked_on": "2026-05-29",
  "locked_decision": "Use KR EEZ+12nm all_touched sea mask, factor-4 max-pooled PH anchor extraction, PH-anchor-first exact-cover sea partitioning, and fallback grid ownership for all remaining valid sea pixels.",
  "description": "Factorized density predictor: a U-Net spatial head predicts a valid-mask-normalized ship-location distribution, and a separate count head predicts total patch count. Final density is count * spatial probability.",
  "device": "mps",
  "sea_mask": {
    "enabled": true,
    "source": "kr_eez_plus_12nm",
    "crop_to_bounds": true,
    "segment_policy": "single_scene",
    "write_masked_tif": true,
    "output_dir": "outputs/dnb_density/preprocessed_scene_masks/density",
    "all_touched": true
  },
  "detector": {
    "name": "DnbCandidateDetector",
    "backend": "cripser",
    "detection_threshold": 1.0,
    "analysis_threshold": 0.25,
    "threshold_reference": "median",
    "smooth_sigma": 0.0,
    "lifetime_limit_fraction": 1.001,
    "area_limit": 0,
    "min_nodes": 4,
    "max_nodes": 2500,
    "remove_edge": false,
    "drop_nested": false
  },
  "ph_downsample": {
    "factor": 4,
    "reducer": "max",
    "scope": "anchor_extraction_only"
  },
  "patching": {
    "padding_pixels": 16,
    "size_divisor": 16,
    "sort_by": "node_count",
    "parent_min_nodes": 32,
    "parent_max_nodes": null,
    "child_min_nodes": 4,
    "child_max_nodes": null,
    "max_children": null,
    "seed_radius_pixels": 1,
    "attention_distance_sigma": 4.0,
    "attention_base_weight": 0.25,
    "attention_ph_weight": 0.75,
    "input_channels": [
      "brightness",
      "parent_ph_mask",
      "child_ph_union_mask",
      "ph_seed_map",
      "ph_persistence_map",
      "ph_soft_attention"
    ],
    "loss_weight": "valid_crop * (0.25 + 0.75 * ph_soft_attention)"
  },
  "partitioning": {
    "enabled": true,
    "fallback_tile_pixels": 96,
    "halo_pixels": 16,
    "anchor_padding_pixels": 16,
    "min_owner_pixels": 1,
    "min_fallback_owner_pixels": 1,
    "policy": "PH anchors claim valid sea pixels first; fallback grid assigns every remaining valid sea pixel exactly once; halo pixels provide context only."
  },
  "target": {
    "kernel": "gaussian",
    "sigma_pixels": 1.5,
    "radius_pixels": 5,
    "renormalize_after_roi_mask": false,
    "require_source_in_roi": false,
    "per_ship_mass": 1.0
  },
  "model": {
    "name": "CountSpatialDensityUNet",
    "in_channels": 6,
    "out_channels": 1,
    "base_channels": 32,
    "depth": 4,
    "count_hidden_channels": 128,
    "count_activation": "exp",
    "dropout": 0.0
  },
  "training": {
    "loss": {
      "name": "count_spatial_density_loss",
      "rationale": "Separates the task into total ship-count regression and spatial allocation. The model predicts one scalar count per patch and one spatial logit map. The loss uses log-count MSE for total count and KL divergence against the sum-normalized target density for localization. The density term is weak and used only to keep the merged count*spatial output numerically grounded. Count head uses exp(raw) so optimization happens naturally in log-count space instead of slowly scaling softplus outputs from near zero.",
      "count_weight": 0.45,
      "spatial_weight": 0.45,
      "density_weight": 0.1,
      "background_weight": 0.0,
      "count_loss": "log_mse",
      "count_huber_delta": 1.0,
      "spatial_loss": "kl",
      "spatial_temperature": 1.0,
      "density_loss": "huber",
      "huber_delta": 0.05,
      "background_target_threshold": 1e-06,
      "min_target_count_for_spatial": 1e-06
    },
    "batch_size": 8,
    "epochs": 20,
    "lr": 0.0001,
    "weight_decay": 0.0001,
    "grad_clip_norm": 1.0
  }
}
